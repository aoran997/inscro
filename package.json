{
  "name": "inscro",
  "version": "0.0.4",
  "description": "Small virtual list primitives and components for React and Vue.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "homepage": "https://github.com/aoran997/inscro#readme",
  "bugs": {
    "url": "https://github.com/aoran997/inscro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoran997/inscro.git"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./pretext": {
      "types": "./dist/pretext.d.ts",
      "import": "./dist/pretext.js",
      "require": "./dist/pretext.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "build:pages": "vite build --outDir dist-pages && touch dist-pages/.nojekyll",
    "demo:react": "vite examples/react --host 127.0.0.1 --port 5173",
    "demo:vue": "vite examples/vue --host 127.0.0.1 --port 5174",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run typecheck && npm run build"
  },
  "keywords": [
    "virtual-list",
    "virtual-scroll",
    "react",
    "vue",
    "typescript"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.5.0",
    "vue": "^3.4.21"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6"
  }
}